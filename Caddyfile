:81 {
        @socket_io {
                path /socket.io /socket.io/*
        }

        handle @socket_io {
                reverse_proxy 127.0.0.1:3003 {
                        header_up Host {host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up X-Real-IP {remote_host}
                }
        }

        @transform_port_query {
                query XTransformPort=*
        }

        handle @transform_port_query {
                # Restrict XTransformPort to known safe ports only (prevents SSRF)
                @port3000 query XTransformPort=3000
                @port3003 query XTransformPort=3003

                @port_denied not @port3000 @port3003
                respond @port_denied "Port not allowed" 403

                reverse_proxy 127.0.0.1:{query.XTransformPort} {
                        header_up Host {host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up X-Real-IP {remote_host}
                }
        }

        handle {
                reverse_proxy 127.0.0.1:3000 {
                        header_up Host {host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up X-Real-IP {remote_host}
                }
        }
}
